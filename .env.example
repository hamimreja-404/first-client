# ============================================================
#  NAJMUL ACADEMY — Example / Template
#  ✅  Commit this file to Git (no real secrets here).
#  📋  Usage: copy this file → .env  and fill in real values.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── Security ────────────────────────────────────────────────
# 🔴 CHANGE THIS to a long random string in production!
#    Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-me

# ── Admin Credentials ───────────────────────────────────────
# 🔴 CHANGE THESE in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# ── URLs ────────────────────────────────────────────────────
# DEV values shown below — replace with your real domain in production.
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Vite exposes only VITE_* vars to the browser bundle.
VITE_API_BASE_URL=http://localhost:3000
VITE_FRONTEND_URL=http://localhost:5173

# ── Cloudinary (Image Upload) ────────────────────────────────────────────────
# REQUIRED on the production server. Leave blank for local dev (falls back to disk).
# Get these from: https://cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
